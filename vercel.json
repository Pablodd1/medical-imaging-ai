{
  "version": 2,
  "name": "medical-imaging-ai",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "SUPABASE_URL": "https://vodhhauwowkalvaxzqyv.supabase.co",
    "SUPABASE_ANON_KEY": "@supabase-anon-key"
  }
}
